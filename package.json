{
  "name": "ateaparty",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "preinstall": "npx only-allow yarn",
    "postinstall": "simple-git-hooks",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier -w --write .",
    "lint:eslint": "eslint . --ext js,jsx,ts,tsx --max-warnings=5",
    "lint:prettier": "prettier --check .",
    "test": "jest",
    "fix": "nr format && eslint --fix .",
    "find-deadcode": "knip",
    "precommit": "ni --frozen && nr lint:eslint && nr lint:prettier",
    "ci": "nr precommit && nr find-deadcode && nr test && nr build"
  },
  "simple-git-hooks": {
    "pre-commit": "nr precommit"
  },
  "dependencies": {
    "@rebass/preset": "4.0.5",
    "@tippyjs/react": "4.2.6",
    "axios": "1.15.0",
    "comma-separated-values": "3.6.4",
    "firebase": "12.12.0",
    "next": "15.5.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-headroom": "3.2.1",
    "react-markdown": "9.1.0",
    "react-twitter-embed": "4.0.4",
    "rebass": "4.0.7",
    "remixicon": "^4.9.1",
    "styled-components": "6.3.11",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/jest": "29.5.14",
    "@types/react": "18.3.18",
    "@types/react-headroom": "3.2.3",
    "@types/rebass": "4.0.15",
    "@typescript-eslint/eslint-plugin": "7.18.0",
    "@typescript-eslint/parser": "7.18.0",
    "autoprefixer": "^10.4.27",
    "babel-plugin-styled-components": "2.1.4",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-unused-imports": "4.4.1",
    "jest": "29.7.0",
    "knip": "^5.86.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "simple-git-hooks": "2.13.1",
    "ts-jest": "29.4.6",
    "typescript": "5.9.3"
  }
}
